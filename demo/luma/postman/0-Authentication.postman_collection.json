{
	"info": {
		"_postman_id": "66f09223-befa-4fee-aee3-aedc32f3451a",
		"name": "0-Authentication",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"_exporter_id": "7048724"
	},
	"item": [
		{
			"name": "Request Access Token",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var data = JSON.parse(responseBody);\r",
							"\r",
							"if (data.access_token) {\r",
							"    pm.environment.set(\"ACCESS_TOKEN\", data.access_token);\r",
							"} else {\r",
							"    console.log(\"Unable to acquire ACCESS_TOKEN from Adobe IMS to make further calls to Adobe I/O APIs.\")\r",
							"}"
						],
						"type": "text/javascript"
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "https://{{IMS}}/ims/token/v2?grant_type=client_credentials&client_id={{API_KEY}}&client_secret={{CLIENT_SECRET}}&scope={{SCOPES}}",
					"protocol": "https",
					"host": [
						"{{IMS}}"
					],
					"path": [
						"ims",
						"token",
						"v2"
					],
					"query": [
						{
							"key": "grant_type",
							"value": "client_credentials"
						},
						{
							"key": "client_id",
							"value": "{{API_KEY}}"
						},
						{
							"key": "client_secret",
							"value": "{{CLIENT_SECRET}}"
						},
						{
							"key": "scope",
							"value": "{{SCOPES}}"
						}
					]
				}
			},
			"response": []
		}
	],
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		}
	]
}